// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Note: Since you are deploying to Vercel, if you aren't using Prisma Accelerate,
  // you might need a directUrl for migrations: directUrl = env("DIRECT_URL")
}

// --- ENUMS ---
enum QualityGrade {
  OEM
  Premium
  Aftermarket
}

enum Role {
  ADMIN
  WHOLESALE
  RETAIL
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

// --- PHASE 2B: AUTHENTICATION ---

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String // Will store the bcrypt hash
  name     String?
  role     Role    @default(RETAIL)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- PHASE 2A: CATALOG & FITMENT ---

model Brand {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  models Model[]
}

model Model {
  id            Int      @id @default(autoincrement())
  brandId       Int
  // Changed to Array to support multiple variants (e.g., ["A2482", "A2631"])
  modelNumbers  String[]
  marketingName String?
  releaseYear   Int?

  brand           Brand              @relation(fields: [brandId], references: [id])
  inventory       Inventory[]
  compatibilities CompatibilityMap[]
}

model Category {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  inventory Inventory[]
}

model Inventory {
  skuId          String        @id
  modelId        Int?
  categoryId     Int
  partName       String?
  specifications String?
  qualityGrade   QualityGrade?
  wholesalePrice Int? // Stored in cents (e.g., 2500 = $25.00)
  stockLevel     Int           @default(0)
  images         String[] // Array of image URLs for the PDP gallery

  model           Model?             @relation(fields: [modelId], references: [id])
  category        Category           @relation(fields: [categoryId], references: [id])
  compatibilities CompatibilityMap[]
  orderItems      OrderItem[] // Relation to track sales
}

model CompatibilityMap {
  id                Int    @id @default(autoincrement())
  skuId             String
  compatibleModelId Int

  inventory Inventory @relation(fields: [skuId], references: [skuId])
  model     Model     @relation(fields: [compatibleModelId], references: [id])

  @@unique([skuId, compatibleModelId])
}

// --- PHASE 2D: CHECKOUT & STRIPE WEBHOOKS ---

model Order {
  id            String      @id @default(cuid())
  userId        String? // Optional: allows for guest checkouts
  stripeSession String?     @unique // The Stripe Checkout Session ID
  totalAmount   Int // Total in cents
  status        OrderStatus @default(PENDING)

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  skuId     String
  quantity  Int
  unitPrice Int // Snapshot of the price at the time of purchase

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventory Inventory @relation(fields: [skuId], references: [skuId])
}
